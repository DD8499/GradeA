# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ─── Google Gemini AI ────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Resend (Email) ─────────────────────────────────────────
RESEND_API_KEY=re_your-resend-key-here
FROM_EMAIL=alerts@gradea.app

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
STRIPE_STARTER_PRICE_ID=price_your-starter-price-id
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# ─── Twilio (SMS / WhatsApp alerts) ─────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_FROM_NUMBER=+12025551234
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── App ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
